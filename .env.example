# =============================================================================
# AI Video Generator - Environment Configuration
# =============================================================================
# This file contains all environment variables required by the application.
# Copy this file to .env and fill in your actual API keys and configuration.
# NEVER commit the .env file to version control.
# =============================================================================

# --- API Keys (Required) ---
# Get your DeepSeek API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Get your Pixabay API key from: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here

# Get your ElevenLabs API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# --- Application Configuration ---

# Backend server settings
HOST=0.0.0.0
PORT=8000

# Database configuration (SQLite)
DATABASE_URL=sqlite:///./video_generator.db

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Maximum video duration in seconds (default: 60)
MAX_VIDEO_DURATION=60

# Maximum number of media items to fetch per search (default: 10)
MAX_MEDIA_PER_SEARCH=10

# ElevenLabs voice ID (default: "21m00Tcm4TlvDq8ikWAM" - Rachel voice)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ElevenLabs model ID (default: "eleven_monolingual_v1")
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# Pixabay image/video orientation (all, horizontal, vertical)
PIXABAY_ORIENTATION=horizontal

# Pixabay minimum image width in pixels (default: 1920)
PIXABAY_MIN_WIDTH=1920

# Pixabay minimum image height in pixels (default: 1080)
PIXABAY_MIN_HEIGHT=1080

# Output video format (mp4, webm, avi)
OUTPUT_VIDEO_FORMAT=mp4

# Output video quality (1-10, where 10 is highest quality)
OUTPUT_VIDEO_QUALITY=8

# Session cleanup interval in minutes (default: 60)
SESSION_CLEANUP_INTERVAL=60

# Session timeout in minutes (default: 1440 = 24 hours)
SESSION_TIMEOUT_MINUTES=1440

# CORS origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=30

# --- Optional Features ---

# Enable/disable debug mode (true/false)
DEBUG=false

# Enable/disable detailed error responses (true/false)
SHOW_DETAILED_ERRORS=false

# Enable/disable request logging (true/false)
ENABLE_REQUEST_LOGGING=true

# --- File Paths ---

# Directory for temporary files
TEMP_DIR=./temp

# Directory for generated videos
VIDEO_OUTPUT_DIR=./output

# Directory for uploaded files
UPLOAD_DIR=./uploads

# --- Security ---

# Secret key for session encryption (generate a random string)
SECRET_KEY=your_secret_key_here_change_in_production

# Allowed file extensions for uploads
ALLOWED_EXTENSIONS=.mp4,.avi,.mov,.jpg,.jpeg,.png,.gif

# Maximum upload file size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800